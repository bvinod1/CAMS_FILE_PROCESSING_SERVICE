# CAMS File Processing Service — Local Environment Variables
# Copy this file to .env and fill in values before running locally.
# .env is git-ignored — never commit real credentials.
#
# Usage:  cp .env.example .env
#         docker-compose --env-file .env up -d
#         # Spring Boot reads system env vars; export the vars or use spring-dotenv

# ---- Object Storage (MinIO) ----
CAMS_STORAGE_ACCESS_KEY=minioadmin
CAMS_STORAGE_SECRET_KEY=minioadmin
CAMS_STORAGE_ENDPOINT=http://localhost:9000

# ---- Database ----
CAMS_DB_URL=jdbc:postgresql://localhost:5432/cams
CAMS_DB_USER=cams
CAMS_DB_PASSWORD=cams

# ---- RabbitMQ ----
CAMS_RABBITMQ_HOST=localhost
CAMS_RABBITMQ_PORT=5672
CAMS_RABBITMQ_USER=cams
CAMS_RABBITMQ_PASSWORD=cams

# ---- External API (WireMock stub in local, real URL in GCP) ----
CAMS_EXTERNAL_API_URL=http://localhost:8089

# ---- Spring Profile ----
SPRING_PROFILES_ACTIVE=local
